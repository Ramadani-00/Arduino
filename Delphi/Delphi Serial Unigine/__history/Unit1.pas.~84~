{$R *.dfm}

procedure TForm1.FormCreate(Sender: TObject);
begin
  edtAddress.Text := '192.168.0.8';
  cbPilihKapal.ItemIndex := 0;

  edtSudutBase.Text := '';
  edtSudutLauncher.Text := '';

  edtSudutBase127.Text := '';
  edtSudutLauncher127.Text := '';

  cbNomorTabung.ItemIndex := 0;
  cbNomorSiloVLS.ItemIndex := 0;
  cbModeTembak35mm.ItemIndex := 0;
  cbNomorTabungTorpedo.ItemIndex := 0;

  // Set default pilihan heli pada ComboBox agar meminimalisasi error kosong di awal
  cbPilihHeli.ItemIndex := 0;

  SpeedRadjiman := 0; SpeedGolok := 0; SpeedBelati := 0; SpeedBrawijaya := 0;
  SpeedFatahillah := 0; SpeedAlugoro := 0; SpeedMartadinata := 0;

  cbPilihKapalChange(Self);
end;

procedure TForm1.UpdateDashboard;
begin
  lblStatusRadjiman.Caption := Format('KRI Radjiman: %.1f Knots', [(Abs(SpeedRadjiman) / 100) * 18]);
  lblStatusGolok.Caption    := Format('KRI Golok: %.1f Knots',    [(Abs(SpeedGolok) / 100) * 30]);
  lblStatusBelati.Caption   := Format('KRI Belati: %.1f Knots',   [(Abs(SpeedBelati) / 100) * 30]);
  lblStatusBrawijaya.Caption   := Format('KRI Brawijaya: %.1f Knots',   [(Abs(SpeedBrawijaya) / 100) * 32]);
  lblStatusFatahillah.Caption   := Format('KRI Fatahillah: %.1f Knots',   [(Abs(SpeedFatahillah) / 100) * 21]);
  lblStatusAlugoro.Caption   := Format('KRI Alugoro: %.1f Knots',   [(Abs(SpeedAlugoro) / 100) * 21]);
  lblStatusReMartadinata.Caption := Format('KRI Re Martadinata: %.1f Knots',   [(Abs(SpeedMartadinata) / 100) * 28]);

  if cbPilihKapal.Text = 'KRI_RADJIMAN' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedRadjiman)) + '%'
  else if cbPilihKapal.Text = 'KRI_GOLOK' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedGolok)) + '%'
  else if cbPilihKapal.Text = 'KRI_BELATI' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedBelati)) + '%'
  else if cbPilihKapal.Text = 'KRI_BRAWIJAYA' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedBrawijaya)) + '%'
  else if cbPilihKapal.Text = 'KRI_FATAHILLAH' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedFatahillah)) + '%'
  else if cbPilihKapal.Text = 'KRI_ALUGORO' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedAlugoro)) + '%'
  else if cbPilihKapal.Text = 'KRI_RE_MARTADINATA' then lblThrottle.Caption := 'Power: ' + IntToStr(Abs(SpeedMartadinata)) + '%';
end;

procedure TForm1.cbPilihKapalChange(Sender: TObject);
var
  I, BatasSilo: Integer;
begin
  if cbPilihKapal.Text = 'KRI_RADJIMAN' then tbThrottle.Position := -SpeedRadjiman
  else if cbPilihKapal.Text = 'KRI_GOLOK' then tbThrottle.Position := -SpeedGolok
  else if cbPilihKapal.Text = 'KRI_BELATI' then tbThrottle.Position := -SpeedBelati
  else if cbPilihKapal.Text = 'KRI_BRAWIJAYA' then tbThrottle.Position := -SpeedBrawijaya
  else if cbPilihKapal.Text = 'KRI_FATAHILLAH' then tbThrottle.Position := -SpeedFatahillah
  else if cbPilihKapal.Text = 'KRI_ALUGORO' then tbThrottle.Position := -SpeedAlugoro
  else if cbPilihKapal.Text = 'KRI_RE_MARTADINATA' then tbThrottle.Position := -SpeedMartadinata;

  cbNomorSiloVLS.Items.Clear;
  if cbPilihKapal.Text = 'KRI_BRAWIJAYA' then
    BatasSilo := 16
  else
    BatasSilo := 12;

  for I := 1 to BatasSilo do
  begin
    cbNomorSiloVLS.Items.Add(IntToStr(I));
  end;
  cbNomorSiloVLS.ItemIndex := 0;

  UpdateDashboard;
end;

procedure TForm1.cbModeTembak35mmChange(Sender: TObject);
begin
  if cbModeTembak35mm.Text = 'SINGLE' then
    KirimPerintah('MODE_35MM_SINGLE')
  else if cbModeTembak35mm.Text = 'BURST' then
    KirimPerintah('MODE_35MM_BURST');
end;

procedure TForm1.btnAutoTrackOnClick(Sender: TObject);
begin
  KirimPerintah('AUTO_TRACK_ON');
end;

procedure TForm1.btnAutoTrackOffClick(Sender: TObject);
begin
  KirimPerintah('AUTO_TRACK_OFF');
  KirimPerintah('CIWS_TEMBAK_STOP');
end;

procedure TForm1.btnTembakCIWS35mmMouseDown(Sender: TObject; Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
begin
  KirimPerintah('CIWS_TEMBAK_START');
end;

procedure TForm1.btnTembakCIWS35mmMouseUp(Sender: TObject; Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
begin
  KirimPerintah('CIWS_TEMBAK_STOP');
end;

procedure TForm1.btnSetSudutClick(Sender: TObject);
var SudutBase, SudutLauncher: Double; fs: TFormatSettings;
begin
  fs := TFormatSettings.Create('en-US');
  SudutBase := StrToFloatDef(edtSudutBase.Text, 0.0);
  SudutLauncher := StrToFloatDef(edtSudutLauncher.Text, 0.0);
  KirimPerintah('SET_ARTILERI_YAW:' + FloatToStr(SudutBase, fs));
  KirimPerintah('SET_ARTILERI_PITCH:' + FloatToStr(SudutLauncher, fs));
end;

procedure TForm1.btnTembakArtileriClick(Sender: TObject);
begin
  KirimPerintah('ARTILERI_TEMBAK');
end;

procedure TForm1.btnTembakMisilClick(Sender: TObject);
begin
  if Trim(cbNomorTabung.Text) <> '' then KirimPerintah('EXOCET_TEMBAK:' + Trim(cbNomorTabung.Text));
end;

