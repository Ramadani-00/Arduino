procedure TForm1.btnHeliAutoLandingClick(Sender: TObject);
begin
  KirimPerintah('HELI_LANDING:' + cbPilihHeli.Text);
end;


procedure TForm1.KirimPerintah(Pesan: string);
var IDKapal: string;
begin
  IDKapal := cbPilihKapal.Text;
  try
  IdTCPClient1.Host := edtAddress.Text;
  IdTCPClient1.Port := 12345;
  if not IdTCPClient1.Connected then
  begin
  IdTCPClient1.ConnectTimeout := 1000;
  IdTCPClient1.Connect;
  end;
  IdTCPClient1.IOHandler.WriteLn(IDKapal + '|' + Pesan);
  except
  end;
end;

procedure TForm1.KirimPerintahKhususAlugoro(Pesan: string);
begin
  try
  IdTCPClient1.Host := edtAddress.Text;
  IdTCPClient1.Port := 12345;
  if not IdTCPClient1.Connected then
  begin
  IdTCPClient1.ConnectTimeout := 1000;
  IdTCPClient1.Connect;
  end;
  IdTCPClient1.IOHandler.WriteLn('KRI_ALUGORO|' + Pesan);
  except
  end;
end;

procedure TForm1.tbThrottleChange(Sender: TObject);
var Nilai: Integer;
begin
  Nilai := -tbThrottle.Position;
  if cbPilihKapal.Text = 'KRI_RADJIMAN' then SpeedRadjiman := Nilai
  else if cbPilihKapal.Text = 'KRI_GOLOK' then SpeedGolok := Nilai
  else if cbPilihKapal.Text = 'KRI_BELATI' then SpeedBelati := Nilai
  else if cbPilihKapal.Text = 'KRI_BRAWIJAYA' then SpeedBrawijaya := Nilai
  else if cbPilihKapal.Text = 'KRI_FATAHILLAH' then SpeedFatahillah := Nilai
  else if cbPilihKapal.Text = 'KRI_ALUGORO' then SpeedAlugoro := Nilai
  else if cbPilihKapal.Text = 'KRI_RE_MARTADINATA' then SpeedMartadinata := Nilai;
  UpdateDashboard; KirimPerintah('THROTTLE:' + IntToStr(Nilai));
end;

