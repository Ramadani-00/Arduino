  if Trim(cbNomorSiloVLS.Text) <> '' then KirimPerintah('VLMICA_TEMBAK:' + Trim(cbNomorSiloVLS.Text));
end;

procedure TForm1.btnReloadVLSClick(Sender: TObject);
begin
  if Trim(cbNomorSiloVLS.Text) <> '' then KirimPerintah('VLMICA_RELOAD:' + Trim(cbNomorSiloVLS.Text));
end;

procedure TForm1.btnTembakTorpedoClick(Sender: TObject);
var SelectedTabung: string;
begin
  SelectedTabung := Trim(cbNomorTabungTorpedo.Text);
  if SelectedTabung <> '' then KirimPerintah('TORPEDO_TEMBAK:' + SelectedTabung);
end;

procedure TForm1.btnReloadTorpedoClick(Sender: TObject);
var SelectedTabung: string;
begin
  SelectedTabung := Trim(cbNomorTabungTorpedo.Text);
  if SelectedTabung <> '' then KirimPerintah('TORPEDO_RELOAD:' + SelectedTabung);
end;

