procedure TfrmLights.Build_Send_Command(var Buff: TBytes; Code: byte; Number: byte; State: byte);
var
  Abytes: TBytes;
begin
  SetLength(ABytes, 3);
  ABytes[0]:= Code;
  ABytes[1]:= Number;
  ABytes[2]:= State;
  TBinaryPacketizer.WrapData(ABytes, Buff);
end;

