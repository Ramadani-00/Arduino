procedure TfrmLights.TmrGetMessageTimer(Sender: TObject);
var
  cmd: string;
begin
  TmrGetMessage.Enabled:= False;

  if MessageQueue.Count>0 then
  begin
    cmd:= MessageQueue.Dequeue;

    Log.Lines.Add(cmd);

  end;

  TmrGetMessage.Enabled:= True;
end;

procedure TfrmLights.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  ComPort1.Close;
//  SetLength(ReceivedBuffer, 0);
end;

procedure TfrmLights.FormCreate(Sender: TObject);
begin
  Packetizer:= TBinaryPacketizer.Create(2048);
  Packetizer.OnPacketReceived:= OnPacketReceivedHandler;
  MessageQueue:= TQueue<string>.Create;
  SetLength(ReceivedBuffer, BufferSize);
//  receivedText:= '';
//  RecvInProgress:= False;

  TmrGetMessage.Interval:= 30;
  TmrGetMessage.Enabled:= True;
end;

procedure TfrmLights.FormDestroy(Sender: TObject);
begin
  ReceivedBuffer:= nil;
  FreeAndNil(MessageQueue);
  FreeAndNil(Packetizer);
end;

procedure TfrmLights.OnPacketReceivedHandler(Packet: TBytes);
var
  i: Integer;
begin
  for i := 0 to Length(Packet)-1 do
    Log.Lines.Add(Packet[i].ToString);
end;

end.
