var
  i: Integer;
begin
  for i := 0 to NumberOfButton - 1 do
  begin
    LEDArray[i] := nil;
    ButtonArray[i] := nil;
    TimerArray[i] := nil;
  end;

  shapeLed01.Tag := 0;
  shapeLed02.Tag := 1;
  shapeLed03.Tag := 2;
  shapeLed04.Tag := 3;
  shapeLed05.Tag := 4;
  shapeLed06.Tag := 5;
  shapeLed07.Tag := 6;
  shapeLed08.Tag := 7;
  shapeLed09.Tag := 8; //
  shapeLed10.Tag := 9;
  shapeLed11.Tag := 10;
  shapeLed12.Tag := 11;


  LEDArray[0] := shapeLed01;
  LEDArray[1] := shapeLed02;
  LEDArray[2] := shapeLed03;
  LEDArray[3] := shapeLed04;
  LEDArray[4] := shapeLed05;
  LEDArray[5] := shapeLed06;
  LEDArray[6] := shapeLed07;
  LEDArray[7] := shapeLed08;
  LEDArray[8] := shapeLed09; //
  LEDArray[9] := shapeLed10;
  LEDArray[10] := shapeLed11;
  LEDArray[11] := shapeLed12;


  TimerArray[0] := Timer1;
  TimerArray[1] := nil;
  TimerArray[2] := nil;
  TimerArray[3] := Timer4;
  TimerArray[4] := Timer5;
  TimerArray[5] := Timer6;
  TimerArray[6] := Timer7;
  TimerArray[7] := Timer8;
  TimerArray[8] := Timer9; //
  TimerArray[9] := Timer10;
  TimerArray[10] := Timer11;
  TimerArray[11] := Timer12;


  Timer1.OnTimer := TimerTimer;
  // Timer2.OnTimer := nil;
  // Timer3.OnTimer := nil;
  Timer4.OnTimer := TimerTimer;
  Timer5.OnTimer := TimerTimer;
  Timer6.OnTimer := TimerTimer;
  Timer7.OnTimer := TimerTimer;
  Timer8.OnTimer := TimerTimer;
  Timer9.OnTimer := TimerTimer; //
  Timer10.OnTimer := TimerTimer;
  Timer11.OnTimer := TimerTimer;
  Timer12.OnTimer := TimerTimer;


end;

procedure TfrmPK_MOC4.OnPacketReceivedHandler(Packet: TBytes);
begin
  MessageQueue.Enqueue(Packet);
end;

procedure TfrmPK_MOC4.SetButtonState(Number, State: Byte);
begin
  if ButtonArray[Number] = nil then
    Exit;

  if State = ON_BUTTON_DOWN then
    ButtonArray[Number].Brush.Color := clRed
  else if State = ON_BUTTON_UP then
    ButtonArray[Number].Brush.Color := clGray;

end;

procedure TfrmPK_MOC4.SetLEDState(Number: Byte; State: Cardinal);
begin
  if LEDArray[Number] = nil then
    Exit;

  if Byte(State) = LED_OFF then
  begin
    LEDArray[Number].Brush.Color := clGray;
    LEDStateArray[Number] := False;
  end
  else if Byte(State) = LED_ON then
  begin
    LEDArray[Number].Brush.Color := clRed;
    LEDStateArray[Number] := True;
  end
end;

procedure TfrmPK_MOC4.SetLEDDisplay(Number: Byte; State: Boolean);
begin
  if LEDArray[Number] = nil then
    Exit;

  if State then
    LEDArray[Number].Brush.Color := clRed
  else
    LEDArray[Number].Brush.Color := clGray
end;

procedure TfrmPK_MOC4.shapeLedMouseUp(Sender: TObject; Button: TMouseButton;
  Shift: TShiftState; X, Y: Integer);
var
  Abytes: TBytes;
  idx: Integer;
  State: Byte;
begin
  idx := TShape(Sender).Tag;
  try
    if LEDStateArray[idx] then
      State := LED_OFF
    else
      State := LED_ON;
    Build_Send_Command(Abytes, LCN_CODE, idx, State);
    ComPort1.Write(Abytes[0], Length(Abytes));
  except
    on E: Exception do
    begin
      Log.Lines.Add(E.Message);
      CloseComPort;
    end;
  end;

end;

procedure TfrmPK_MOC4.Sync_LED_State;
var
  Abytes: TBytes;
begin
  try
    Build_Send_Command(Abytes, LGA_CODE, 0, 0);
    ComPort1.Write(Abytes[0], Length(Abytes));
  except
    on E: Exception do
    begin
      Log.Lines.Add(E.Message);
      CloseComPort
    end;
  end;
end;

end.
